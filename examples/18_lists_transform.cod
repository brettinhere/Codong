// 18 — List Transformations
nums = [1, 2, 3, 4, 5, 6]

// map — transform each element
squared = nums.map(fn(x) => x * x)
print(squared.join(" "))

// filter — keep matching elements
evens = nums.filter(fn(x) => x % 2 == 0)
print(evens.join(" "))

// reduce — accumulate into single value
sum = nums.reduce(fn(acc, x) => acc + x, 0)
print("sum: {sum}")

// find — first match
found = nums.find(fn(x) => x > 3)
print("first > 3: {found}")

// find_index
idx = nums.find_index(fn(x) => x > 3)
print("index of first > 3: {idx}")

// flat — flatten nested lists
nested = [[1, 2], [3, 4], [5]]
print(nested.flat().join(" "))

// unique — remove duplicates
dupes = [1, 2, 2, 3, 3, 3]
print(dupes.unique().join(" "))
