// 15 — Closures
// Counter closure
fn make_counter() {
    count = 0
    fn increment() {
        count += 1
        return count
    }
    return increment
}
c = make_counter()
print("count: {c()}")
print("count: {c()}")
print("count: {c()}")

// make_adder
fn make_adder(n) {
    return fn(x) => x + n
}
add5 = make_adder(5)
print("add5(3) = {add5(3)}")
print("add5(10) = {add5(10)}")
