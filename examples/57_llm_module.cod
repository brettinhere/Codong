// Count tokens (rough estimate)
tokens = llm.count_tokens("Hello, this is a test of the token counter.")
print("estimated tokens: {tokens}")

// Error handling without API key
result = llm.ask("test", model: "gpt-4o")
if type_of(result) == "error" {
    print("expected error: {result.code}")
    print("fix: {result.fix}")
}
