// 07 — Compound assignment
x = 10
x += 5;  print("+=: {x}")
x -= 3;  print("-=: {x}")
x *= 2;  print("*=: {x}")
x /= 4;  print("/=: {x}")

// On map properties
m = {count: 0}
m.count += 1
m.count += 1
print("map +=: {m.count}")

// On list indices
l = [10, 20, 30]
l[1] += 100
print("list +=: {l[1]}")

// String +=
s = "hello"
s += " world"
print(s)
